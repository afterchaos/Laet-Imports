# Server
PORT=3000
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_DIR=/uploads

# Admin auth
ADMIN_TOKEN=admin-token

# Persistence mode
# DATABASE_MODE=postgres -> tenta Postgres e faz fallback automático para JSON se falhar
# DATABASE_MODE=local    -> ignora Postgres e usa apenas JSON
DATABASE_MODE=postgres

# PostgreSQL (usado quando DATABASE_MODE=postgres)
# Preferido: DATABASE_URL
DATABASE_URL=

# Alternativo:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=laet

# Se usar SSL no Postgres
# PGSSL=false

